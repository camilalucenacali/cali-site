---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import PaymentModal from '../components/PaymentModal.astro';
import { workshops } from '../data/workshops.js';

const eventSchemas = workshops
  .filter(w => w.date)
  .map(w => ({
    "@context": "https://schema.org",
    "@type": "Event",
    "name": `Imersão CALI — Yoga e Movimento com Camila Lucena`,
    "description": "Experiência de 2h de yoga, movimento e expressão corporal com Camila Lucena. Inclui Hatha Yoga clássico, Nauli e invertidas.",
    "startDate": w.date,
    "location": {
      "@type": "Place",
      "name": w.location,
      "address": { "@type": "PostalAddress", "addressLocality": w.city }
    },
    "organizer": { "@type": "Person", "name": "Camila Lucena" },
    "offers": {
      "@type": "Offer",
      "price": w.currency === 'EUR' ? w.priceEUR?.earlyBird : w.priceBRL?.earlyBird,
      "priceCurrency": w.currency,
      "availability": "https://schema.org/InStock"
    }
  }));
---

<BaseLayout
  title="Imersões de Yoga — CALI MOVIMIENTO by Camila Lucena"
  description="Imersões de yoga e movimento com Camila Lucena. Rio de Janeiro, Florianópolis, Porto Alegre e Europa. Reserve o teu lugar."
>
  {eventSchemas.map(schema => (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} slot="head" />
  ))}

  <Header />

  <!-- Hero -->
  <section style="padding:9rem 2rem 4rem;text-align:center;background:radial-gradient(ellipse at 50% 0%,#12113a 0%,#080818 70%);">
    <div class="stars-container" id="stars"></div>
    <div style="position:relative;z-index:2;max-width:700px;margin:0 auto;">
      <p class="eyebrow reveal">agenda 2026</p>
      <h1 class="section-title reveal" style="font-size:clamp(3rem,8vw,6rem);">Imersões</h1>
      <p class="tagline reveal">
        Onde o corpo aprende a se habitar.<br>
        Brasil e Europa — sempre em movimento.
      </p>
    </div>
  </section>

  <!-- Banner — o que está incluído -->
  <section style="padding:1.2rem 2rem;background:linear-gradient(90deg,rgba(255,107,53,0.12),rgba(168,85,247,0.12));border-top:1px solid rgba(255,107,53,0.2);border-bottom:1px solid rgba(255,107,53,0.2);">
    <div class="container" style="text-align:center;">
      <p style="font-size:0.9rem;color:rgba(255,255,255,0.9);letter-spacing:0.03em;">
        ✦ Todas as imersões incluem <strong>material impresso</strong> para continuar praticando em casa + <strong>acesso ao APP Spine Lab</strong> ✦
      </p>
    </div>
  </section>

  <!-- Pricing legend -->
  <section style="padding:2rem;background:#080818;">
    <div class="container">
      <div style="display:flex;gap:1rem;flex-wrap:wrap;justify-content:center;" class="reveal">
        <div style="background:rgba(255,107,53,0.1);border:1px solid rgba(255,107,53,0.3);border-radius:10px;padding:0.6rem 1.2rem;font-size:0.85rem;">
          🐦 <strong>Early bird</strong> — 3+ dias antes
        </div>
        <div style="background:rgba(255,255,255,0.04);border:1px solid var(--border);border-radius:10px;padding:0.6rem 1.2rem;font-size:0.85rem;">
          Regular — até 1 dia antes
        </div>
        <div style="background:rgba(233,30,140,0.08);border:1px solid rgba(233,30,140,0.2);border-radius:10px;padding:0.6rem 1.2rem;font-size:0.85rem;">
          No dia
        </div>
        <div style="background:rgba(0,179,116,0.1);border:1px solid rgba(0,179,116,0.3);border-radius:10px;padding:0.6rem 1.2rem;font-size:0.85rem;color:#00b374;">
          💚 PIX = 10% de desconto em qualquer valor
        </div>
      </div>
    </div>
  </section>

  <!-- Grid único — todas as imersões, máx 3 por linha -->
  <section style="padding:4rem 2rem 5rem;background:#080818;">
    <div class="container">
      <div class="grid-3">
        {workshops.map((w, i) => {
          const earlyBRL = w.priceBRL?.earlyBird;
          const regBRL   = w.priceBRL?.regular;
          const dayBRL   = w.priceBRL?.dayOf;
          const earlyEUR = w.priceEUR?.earlyBird;
          const regEUR   = w.priceEUR?.regular;
          const dayEUR   = w.priceEUR?.dayOf;
          const isTbd    = w.status === 'tbd';

          return (
            <div
              class={`card reveal imersao-card${isTbd ? ' card-tbd' : ''}`}
              data-event-date={w.date ?? ''}
              data-early={w.currency === 'EUR' ? earlyEUR : earlyBRL}
              data-regular={w.currency === 'EUR' ? regEUR : regBRL}
              data-dayof={w.currency === 'EUR' ? dayEUR : dayBRL}
              data-currency={w.currency}
              style={`transition-delay:${i*0.1}s;position:relative;`}
            >
              {isTbd && (
                <span style="position:absolute;top:1rem;right:1rem;background:rgba(233,30,140,0.15);border:1px solid rgba(233,30,140,0.4);border-radius:20px;padding:0.2rem 0.7rem;font-size:0.72rem;letter-spacing:0.05em;color:#e91e8c;">
                  Em breve
                </span>
              )}

              <p class="workshop-date">{w.dateDisplay}</p>
              <p class="workshop-city" style="font-size:1.15rem;">{w.neighborhood || w.city}</p>
              <p class="workshop-location">{w.location}</p>
              <p class="workshop-time">⏰ {w.time}{!isTbd ? ' · 2 horas' : ''}</p>

              <div style="margin:0.8rem 0 0.4rem;">
                <span class="price-tier-badge" style="display:inline-block;background:rgba(255,107,53,0.12);border:1px solid rgba(255,107,53,0.3);border-radius:8px;padding:0.25rem 0.7rem;font-size:0.78rem;color:var(--orange);margin-bottom:0.5rem;"></span>
              </div>
              <div class="price-row" style="margin-bottom:0.5rem;">
                <span class="price-main tier-price" style="font-family:var(--font-display);font-size:2rem;"></span>
                <span class="tier-pix" style="font-size:0.85rem;color:#00b374;margin-left:0.4rem;"></span>
              </div>

              {w.addOn && (
                <p style="font-size:0.8rem;color:var(--muted);margin-bottom:1rem;">
                  🍱 Opcional: {w.addOn.label} — R${w.addOn.price}
                </p>
              )}

              <button
                class="btn btn-primary"
                style={`width:100%;text-align:center;margin-top:auto;${isTbd ? 'opacity:0.5;' : ''}`}
                data-workshop={`${w.city}${w.neighborhood ? ' — ' + w.neighborhood : ''} · ${w.dateDisplay} ${w.time}`}
                data-price={w.currency === 'EUR' ? earlyEUR : earlyBRL}
                data-currency={w.currency}
                data-addon-price={w.addOn?.price ?? ''}
                data-addon-label={w.addOn?.label ?? ''}
                disabled={isTbd}
              >
                {isTbd ? 'Em breve — aguarde' : 'Reservar lugar'}
              </button>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Online / Zoom -->
  <section style="padding:5rem 2rem;background:linear-gradient(180deg,#080818 0%,#0d0d28 100%);">
    <div class="container" style="max-width:700px;text-align:center;">
      <p class="eyebrow reveal">também disponível</p>
      <h2 class="section-title reveal" style="margin-bottom:1.2rem;">Aulas online via Zoom</h2>
      <p class="reveal" style="color:var(--muted);line-height:1.9;margin-bottom:2rem;">
        Não consegues estar presencialmente? A prática também acontece online, com a mesma presença e intenção. Estarei inteiramente disposta a te entender e vivenciar contigo.
      </p>
      <a href={`https://wa.me/5551999595522?text=${encodeURIComponent('Olá Cami! Quero saber mais sobre as aulas online.')}`}
         target="_blank" rel="noopener" class="btn btn-outline reveal">
        Perguntar sobre aulas online
      </a>
    </div>
  </section>

  <Footer />
  <WhatsAppButton />
  <PaymentModal />
</BaseLayout>

<script>
  // Stars
  function makeStars(id, n = 120) {
    const c = document.getElementById(id);
    if (!c) return;
    for (let i = 0; i < n; i++) {
      const s = document.createElement('div');
      s.className = 'star';
      const sz = Math.random() * 2 + 0.5;
      s.style.cssText = `width:${sz}px;height:${sz}px;left:${Math.random()*100}%;top:${Math.random()*100}%;--d:${2+Math.random()*4}s;--delay:${Math.random()*5}s;`;
      c.appendChild(s);
    }
  }
  makeStars('stars');

  // Dynamic pricing — calcula tier com base na data atual
  function getPriceTier(dateStr) {
    if (!dateStr) return 'earlyBird';
    const today     = new Date(); today.setHours(0,0,0,0);
    const eventDate = new Date(dateStr + 'T00:00:00');
    const days      = Math.floor((eventDate - today) / 86400000);
    if (days >= 3) return 'earlyBird';
    if (days <= 0) return 'dayOf';
    return 'regular';
  }

  const TIER_LABELS = {
    earlyBird: '🐦 Early bird',
    regular:   'Regular',
    dayOf:     'No dia',
  };

  document.querySelectorAll('.imersao-card').forEach(card => {
    const dateStr  = card.dataset.eventDate;
    const early    = parseFloat(card.dataset.early   || 0);
    const regular  = parseFloat(card.dataset.regular || 0);
    const dayof    = parseFloat(card.dataset.dayof   || 0);
    const curr     = card.dataset.currency === 'EUR' ? '€' : 'R$';

    const prices   = { earlyBird: early, regular, dayOf: dayof };
    const tier     = getPriceTier(dateStr || null);
    const price    = prices[tier] || early;
    const pix      = Math.round(price * 0.9 * 100) / 100;

    function fmt(v) { return curr + v.toFixed(2).replace('.', ','); }

    const badge = card.querySelector('.price-tier-badge');
    const tierEl = card.querySelector('.tier-price');
    const pixEl  = card.querySelector('.tier-pix');
    const btn    = card.querySelector('[data-workshop]');

    if (badge)  badge.textContent  = TIER_LABELS[tier] || '';
    if (tierEl) tierEl.textContent = fmt(price);
    if (pixEl)  pixEl.textContent  = `· ${fmt(pix)} PIX`;
    if (btn && !card.classList.contains('card-tbd')) {
      btn.dataset.price = price;
    }
  });
</script>

<style>
  .card-tbd { opacity: 0.75; }
  .card-tbd .btn[disabled] { cursor: not-allowed; }
</style>
